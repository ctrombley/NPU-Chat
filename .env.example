# NPU-Chat Environment Configuration
# Copy this file to .env and adjust values as needed.

# --- Web UI ---
BINDING_ADDRESS=0.0.0.0
BINDING_PORT=1314

# --- NPU/LLM Server (legacy single-model config) ---
NPU_ADDRESS=192.168.0.196
NPU_PORT=31337
CONNECTION_TIMEOUT=45

# --- Model Registry (optional, overrides NPU_ADDRESS/NPU_PORT) ---
# JSON mapping role → {address, port, timeout, serialize}
# If not set, all roles use NPU_ADDRESS:NPU_PORT
# MODEL_REGISTRY={"chat": {"address": "0.0.0.0", "port": 8089, "timeout": 300, "serialize": true}, "metadata": {"address": "0.0.0.0", "port": 8090, "timeout": 60, "serialize": true}}

# --- Context ---
USE_CONTEXT=True
CONTEXT_DEPTH=1

# --- Database ---
# SQLite (default):
# DATABASE_URL=sqlite:///data/chats.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/npuchat

# --- Logging ---
# LOG_FORMAT: json (default) or text (for local dev)
LOG_FORMAT=json
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_STORAGE_URI=memory://
